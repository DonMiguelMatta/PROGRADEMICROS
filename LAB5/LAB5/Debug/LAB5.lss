unsigned int Servo_mapADC(unsigned int adcValue)
{
	// Mapear ADC 0-1023 a pulso de 500 us a 2500 us
	return (SERVO_MIN_US + ((unsigned long)adcValue * (SERVO_MAX_US - SERVO_MIN_US)) / 1023UL);
